# Copy this to .env and fill in your values.
# Never commit the actual .env file.

# From Discord Developer Portal > Bot > Token
DISCORD_BOT_TOKEN=

# Right-click the channel in Discord (with Developer Mode on) > Copy Channel ID
DISCORD_SUBMISSION_CHANNEL_ID=

# From Convex dashboard > Settings > URL — looks like: https://xxxx.convex.site
CONVEX_SITE_URL=

# Any random secret — must match BOT_SECRET set in Convex environment variables
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BOT_SECRET=

# Optional: separate channel for bot confirmation logs
DISCORD_LOG_CHANNEL_ID=
